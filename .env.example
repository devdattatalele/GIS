# GIS - GitHub Issue Solver
# Copy to .env or run: gis setup

# ── LLM Provider ──────────────────────────────────────────────
# Options: gemini, claude, grok, openai, ollama
LLM_PROVIDER=gemini

# API key for your chosen provider (only one needed)
GOOGLE_API_KEY=                  # gemini  — https://makersuite.google.com/app/apikey
# ANTHROPIC_API_KEY=             # claude  — https://console.anthropic.com/settings/keys
# XAI_API_KEY=                   # grok    — https://console.x.ai/
# OPENAI_API_KEY=                # openai  — https://platform.openai.com/api-keys
# (ollama needs no key)

# Override default model (optional)
# LLM_MODEL_NAME=gemini-2.5-pro

# ── GitHub ────────────────────────────────────────────────────
# Scopes: repo, read:org — https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Embeddings ────────────────────────────────────────────────
# fastembed = offline, fast, free | google = cloud, higher quality
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# ── Storage ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── Ingestion Limits ──────────────────────────────────────────
MAX_ISSUES=100
MAX_PRS=15                       # keep low for large repos (curl/curl etc.)
MAX_FILES=50

# ── Optional ──────────────────────────────────────────────────
ENABLE_PATCH_GENERATION=true
LOG_LEVEL=INFO
# GOOGLE_DOCS_ID=                # for analysis report export
